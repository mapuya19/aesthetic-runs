# PostgreSQL Connection (Supabase or Local)
# Supabase format: postgresql://postgres:[PASSWORD]@[PROJECT-URL].supabase.co:5432/postgres
# Local format: postgresql://username:password@localhost:5432/database?schema=public
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-URL].supabase.co:5432/postgres"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Server
PORT=8000
NODE_ENV=development
