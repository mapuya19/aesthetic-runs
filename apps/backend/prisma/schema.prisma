generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  distance    Float
  originLat   Float
  originLng   Float
  destLat     Float
  destLng     Float
  waypoints   Json
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
